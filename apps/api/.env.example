# ─── Runtime ──────────────────────────────────────────────────────────────
# One of: dev | staging | prod
NODE_ENV=dev
# Port the NestJS API listens on
PORT=3000
# Comma-separated origins allowed to call the API (the web app in dev)
CORS_ORIGIN=http://localhost:5173

# ─── Database (MySQL 8, InnoDB + utf8mb4) ─────────────────────────────────
# Matches docker-compose.yml credentials in local dev.
# The database must be created with utf8mb4 / utf8mb4_unicode_ci.
DATABASE_URL="mysql://cpp:cpp_local_dev@localhost:3307/cost_provision"
# Shadow DB for `prisma migrate dev` (lets a restricted user migrate without
# global CREATE DATABASE rights). Create it with utf8mb4 too.
SHADOW_DATABASE_URL="mysql://cpp:cpp_local_dev@localhost:3307/cost_provision_shadow"

# ─── Auth / JWT ───────────────────────────────────────────────────────────
# Use long, random, distinct secrets per environment
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
# Short-lived access token; longer-lived rotating refresh token
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# bcrypt cost factor (must be >= 12)
BCRYPT_ROUNDS=12

# ─── Email (AWS SES via Nodemailer) ───────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=no-reply@example.com
