# Vite only exposes vars prefixed with VITE_ to the client.

# One of: dev | staging | prod
VITE_NODE_ENV=dev
# Base URL of the NestJS API (includes the /api global prefix)
VITE_API_BASE_URL=http://localhost:3000/api
# Optional: idle auto-logout in milliseconds (default 1800000 = 30 min).
# Lower it to exercise the idle-logout flow quickly, e.g. 10000 for 10s.
# VITE_IDLE_TIMEOUT_MS=1800000
